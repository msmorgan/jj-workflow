{
  "env": {
    "JJ_EDITOR": "false"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "fish \"$CLAUDE_PROJECT_DIR/scripts/hooks/jj_guard.fish\""
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "fish \"$CLAUDE_PROJECT_DIR/scripts/hooks/worktree_create.fish\""
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "fish \"$CLAUDE_PROJECT_DIR/scripts/hooks/worktree_remove.fish\""
          }
        ]
      }
    ]
  }
}
