#!/usr/bin/env fish
# scripts/jj — workspace-pinned, trunk-guarded jj. Run it in place of `jj`:
# `scripts/jj <args…>` (don't source it).
#
# Pins jj to THIS workspace via `-R $project_dir`, which tracks wherever this copy
# of the script lives (feature workspaces each get their own checkout). In any
# workspace other than `default` it also marks the whole default line immutable —
# `immutable_heads() = default@-`, i.e. `::default@-`: trunk plus every claim
# commit, but NOT default@ itself. default@ is default's working-copy commit and
# MUST stay mutable — naming it immutable forces jj to work around it (strand it
# as a new empty commit) every time a snapshot or divergent-op reconciliation
# needs to update it, which is what made default@ churn and empties pile up. The
# parent `default@-` is the last *committed* point on the line, so this still
# refuses any rewrite reaching shared history, while the agent's own feature work
# (which branches off to the side of default@, not an ancestor of it) stays
# editable. It also refuses --config / --config-file /
# --ignore-immutable, the three flags that would let the caller override the guard.
# `default`, the coordinator, is left unguarded so you can go in and fix things.


set scripts_dir (path resolve (status dirname))
set project_dir (path resolve $scripts_dir/..)
set -g jj_args -R $project_dir

# Fail fast instead of hanging if a command would open an editor (describe/squash
# without -m, split -i, resolve, …). JJ_EDITOR outranks ui.editor / $VISUAL /
# $EDITOR, so `false` makes jj abort with a clear error rather than block a
# scripted run. Interactive jj and the IDE (which don't go through this wrapper)
# keep their real editor.
set -x JJ_EDITOR false

# Make sure this dir isn't on $PATH before `command jj`.
set i 1
while set -q PATH[$i]
    while test "$(path resolve $PATH[$i])" = "$scripts_dir"
        set -e PATH[$i]
    end
    set i (math $i + 1)
end

#alias jj 'command jj $jj_args'
function jj
    command jj $jj_args $argv
end

set default_root (jj workspace root --name default 2>/dev/null)
test -n "$default_root"; and set default_root (path resolve $default_root)
if test "$project_dir" != "$default_root"
    set -a jj_args --config 'revset-aliases."immutable_heads()"=default@-'
end

# Non-capturing groups: `string match -r` returns capture groups next to the full
# match, so (?:…) keeps $illegal_flags to just the offending flags.
if set illegal_flags (string match -r -- '^--(?:ignore-immutable|config(?:-file)?(?:=.*)?)$' $argv)
    echo >&2 "scripts/jj: refusing $illegal_flags — it would bypass the workspace guard."
    exit 2
end

jj $argv
