#!/usr/bin/env fish

# Resolve this script's real location first (it may be invoked through a
# symlink, e.g. a plugin's bin/), then let setup.fish derive $project_dir from
# the CWD's jj workspace root — every command targets where you RUN it.
source (path dirname (path resolve (status filename)))/lib/setup.fish flock
or return

# Most commands run from default. repair/converge/resolve heal a feature
# workspace in place, and no-arg refresh rebases the current feature stack —
# none touch default's shared line, so they're safe from any workspace.
if not contains -- "$argv[1]" repair converge resolve refresh; and test "$project_dir" != "$(path resolve (jj workspace root --name default))"
    echo >&2 "$(status filename): intended to be run from default workspace only (except 'refresh'/'repair'/'converge'/'resolve')."
    return 1
end

function __workflow_usage
    echo >&2 "\
Usage: $(status filename) <command> [<args>]
  Commands:
    claim TODO           Claim a todo item and start a workspace named TODO.
    claim TODO... --into NAME
                         Fold each TODO into the EXISTING workspace NAME's claim
                         instead of starting a new workspace — NAME then owns those
                         tickets too, and `integrate NAME` finishes them all. Use this
                         to take on extra todos after a workspace is already going.
                         (NAME's workspace goes stale; run `workspace update-stale`
                         there.)
    claim NAME --or-start
                         Claim NAME if it names a claimable ticket/census row,
                         else fall back to `start NAME` (what the Claude Code
                         worktree hook calls).
    start NAME           Spin up an ad-hoc workspace named NAME, with no todo to claim.
    drop WORKSPACE       Retire WORKSPACE and delete its directory (the default next
                         step after integrate). Refuses if the workspace holds
                         un-integrated work; `drop --force` discards the claim and
                         stack outright (recoverable via op log until gc).
    drop --integrated    Sweep EVERY integrated, empty workspace at once — the bulk
                         post-integrate cleanup. Skips `default`, the one you're in,
                         un-integrated workspaces, and any resumed with new work.
                         `drop --integrated --dry-run` lists what it would drop.
    refresh [WORKSPACE]  From a feature workspace (no WORKSPACE): rebase its stack onto
                         the trunk tip (default@-), detaching it from its claim (integrate
                         re-joins). From default with a WORKSPACE: reorder that claim to
                         sit just under default@, feature carried along (the old behavior).
                         Always refresh before any review step.
    refresh --all        Reorder EVERY non-default workspace's claim under default@ (prep
                         for a push), stopping at the first that conflicts or fails.
    integrate WORKSPACE  Refresh, re-join the claim to the feature, fold WORKSPACE's
                         work into default@. Then `drop WORKSPACE` to retire it — the
                         default next step, so the directory doesn't dangle. The
                         workspace is KEPT (not auto-dropped) so you can instead resume
                         there if there's follow-up work.
    repair               Run FROM a feature workspace: one-stop "my branch shifted under me"
                         recovery = update-stale + converge + resolve. Exit 0 clean; exit 1 fix
                         the conflict markers (jj st) and re-run; exit 2 needs a human.
    converge             Run FROM a feature workspace: heal a working-copy divergence left
                         by a concurrent op — keep the half holding your work, drop the rest.
    resolve              Run FROM a feature workspace to walk a refresh/integrate conflict one
                         commit at a time: drops you onto a conflict (exit 1); remove its
                         markers; re-run. Exit 0 once the stack is clean.
"
    exit 2
end

if not set -q argv[1]
    __workflow_usage
end

# The op-log savepoint the transactional commands roll back to on failure.
function __savepoint
    jj op log -n1 -G -T 'id.short()'
end

# Announce and restore the op log to $savepoint; callers add extra cleanup.
function __rollback --argument-names savepoint
    echo >&2 "Failed... restoring to $savepoint"
    jj op restore "$savepoint"
end

# Path of NAME's ticket in a triage folder (critical/planned/maybe), if any.
function __ticket_triage_path --argument-names name
    for folder in critical planned maybe
        set -l p "$project_dir/docs/tickets/$folder/$name.md"
        if test -f $p
            echo $p
            return 0
        end
    end
    return 1
end

# Resolved path of the project's ticket/census tool (jjworkflow.toml todo_cmd,
# relative to the repo root unless absolute; default scripts/todo).
function __todo_cmd
    set -l cmd (__jjworkflow_config todo_cmd scripts/todo)
    string match -q -- '/*' $cmd; or set cmd $project_dir/$cmd
    echo $cmd
end

# NAME's ticket lifecycle state: triage | wip | done | census | unknown.
function __ticket_state --argument-names name
    set -l tickets "$project_dir/docs/tickets"
    if __ticket_triage_path $name >/dev/null
        echo triage
    else if test -f "$tickets/wip/$name.md"
        echo wip
    else if test -f "$tickets/done/$name.md"
        echo done
    else
        set -l cmd (__todo_cmd)
        if test -x "$cmd"; and "$cmd" iscensus $name >/dev/null 2>&1
            echo census
        else
            echo unknown
        end
    end
end

# Roots of NAME's feature stack — the commits only NAME@ has. Correct whether
# the stack sits on its claim or was DETACHED onto the trunk tip by a no-arg
# refresh. (A `children(NAME)` lookup resolves to a TRUNK commit on a detached
# stack — and `::` from there sweeps default's line, sibling claims and all.)
function __feature_roots --argument-names name
    jj log --no-graph -r "roots(default@..$name@)" -T 'change_id.short() ++ "\n"'
end

# Bank every workspace's on-disk edits into its WC commit before an operation
# that rewrites default's shared line (integrate, reorder refresh, drop).
# The rewrite rebases the other workspaces' WC commits; an edit still sitting
# un-snapshotted on disk would otherwise be re-snapshotted into the OLD
# (hidden) commit by that workspace's next command — the two-successor
# working-copy divergence. Runs under the caller's flock. An already-stale
# workspace refuses the snapshot — skip it: its own session owns that
# recovery, and its WC is banked as of its last op anyway.
function __snapshot_workspaces
    for ws in (jj workspace list -T 'name ++ "\n"')
        set -l root (jj workspace root --name $ws 2>/dev/null); or continue
        command jj -R "$root" util snapshot >/dev/null 2>&1
    end
end

# P1: the trunk tip we anchor rebases on must be a single commit. `fork_point(x)`
# == x for a single commit and the parents' common ancestor (∉ default@-) for a
# merge, so the intersection is empty exactly when default@ is a merge.
function __require_linear_trunk
    if test -z "$(jj log --no-graph -r 'default@- & fork_point(default@-)' -T 'change_id' --ignore-working-copy)"
        echo >&2 "$(status filename): default@ is a merge; the coordinator line must be linear — abandon or resolve the merge, then retry."
        return 2
    end
end

# Scan REVSET for recorded conflicts (a conflicted rebase exits 0). If any:
# leave them in place and return the 69 "expected stop" sentinel (wrapper maps
# it to exit 2; integrate refuses to fold past it). Else 0.
function __conflict_stop --argument-names revset ws_dir what
    set -l conflicted (jj log --no-graph -r "$revset & conflicts()" -T 'change_id.short()' --ignore-working-copy)
    test -z "$conflicted"; and return 0
    echo >&2 "$(status filename): $what — resolve it in $ws_dir, then re-run."
    return 69
end

# Claim NAME: move its ticket into wip/. From a triage folder (critical/planned/
# maybe) it's a rename; a census-only mechanic is minted fresh into wip/. The move
# or add lands in the claim commit, so `drop` reverts it automatically. An
# already-claimed (wip/) or finished (done/) name, or an unknown one, fails the claim.
function __claim_todo
    set -l name $argv[1]
    set -l tickets "$project_dir/docs/tickets"
    # wip/ may be absent on disk (empty dirs aren't tracked) — ensure it exists
    # before the move or census mint lands in it.
    mkdir -p "$tickets/wip"
    or return
    switch (__ticket_state $name)
        case triage
            mv (__ticket_triage_path $name) "$tickets/wip/$name.md"
            # switch propagates mv's status — never mask a failure
        case wip
            echo >&2 "$(status filename): '$name' is already claimed (in wip/)."
            return 1
        case done
            echo >&2 "$(status filename): '$name' is already done."
            return 1
        case census
            set -l cmd (__todo_cmd)
            "$cmd" mint $name >"$tickets/wip/$name.md"
            and test -s "$tickets/wip/$name.md"
            and return 0
            rm -f "$tickets/wip/$name.md"
            echo >&2 "$(status filename): minting '$name' from the census failed."
            return 1
        case unknown
            echo >&2 "$(status filename): no ticket or census row named '$name'."
            return 1
    end
end

# Finish each NAMED ticket: wip/ -> done/. Tolerant — a name with no wip/ ticket
# (ad-hoc feature, already-moved slug) is skipped, and an empty list is success.
# integrate passes every ticket the claim commit owns.
function __check_todo
    set -l tickets "$project_dir/docs/tickets"
    set -q argv[1]; or return 0          # nothing to finish (ad-hoc / empty list)
    # done/ may not exist yet (empty dirs aren't tracked) — create it before any move.
    mkdir -p "$tickets/done"; or return
    for name in $argv
        test -f "$tickets/wip/$name.md"; or continue
        mv "$tickets/wip/$name.md" "$tickets/done/$name.md"; or return
    end
end

# Read a flat `key = "value"` (or `key = value`) line from jjworkflow.toml, or
# echo DEFAULT. Deliberately dumb — no TOML parser dependency; flat keys only.
function __jjworkflow_config --argument-names key default
    set -l cfg $project_dir/jjworkflow.toml
    if test -f $cfg
        set -l val (string match -rg "^\s*$key\s*=\s*[\"']?([^\"'#]*?)[\"']?\s*(?:#.*)?\$" <$cfg)
        if test -n "$val"
            echo $val
            return
        end
    end
    echo $default
end

# Base directory holding feature workspaces. jjworkflow.toml `workspace_dir`,
# resolved against the project root unless absolute; default `..` — workspaces
# as siblings of the project dir.
# An in-repo base (e.g. `.claude/worktrees`) MUST be gitignored, or jj would
# snapshot every child workspace into the coordinator's working copy.
function __workspace_base
    set -l dir (__jjworkflow_config workspace_dir ..)
    if string match -q -- '/*' $dir
        path resolve -- $dir
    else
        path resolve -- $project_dir/$dir
    end
end

# `jj workspace add` only checks out tracked files; an executable at
# $provision_hook (default scripts/provision-workspace), run with the new
# workspace dir as $argv[1], provides the rest. No hook -> no-op.
function __provision_ws --argument-names ws_dir
    set -l hook (__jjworkflow_config provision_hook scripts/provision-workspace)
    set -l hook_path $project_dir/$hook
    if test -x "$hook_path"
        if not "$hook_path" "$ws_dir"
            echo >&2 "$(status filename): provision hook '$hook' failed for $ws_dir — finish provisioning by hand."
            return 1
        end
    end
end

# Spin up a NAME-bookmarked base commit on default@- with a NAME workspace dir
# (under the configured workspace base, default ../NAME) on top, leaving
# default's @ put. The base commit starts EMPTY; ticket ownership is always
# folded in afterwards by __workflow_adopt (claim = start + adopt), so this is
# the single workspace-creation path and adopt the single ticket-move path.
function __workflow_start
    set name "$argv[1]"
    if test "$name" = -h; or test "$name" = --help
        __workflow_usage
        return 0
    end
    if string match -rq -- '^-' "$name"
        echo >&2 "$(status filename): NAME may not start with '-' (got '$name'). Did you mean '--help'?"
        return 2
    end
    if test -z $name
        echo >&2 "$(status filename): a workspace NAME is required."
        return 2
    end
    if set -q argv[2]
        echo >&2 "$(status filename): expected exactly one NAME (got: $argv)."
        return 2
    end
    set ws_dir (__workspace_base)/$name
    # Refuse a pre-existing dir up front: `jj workspace add` would fail mid-sequence
    # with a cryptic "destination exists", and knowing it's absent now lets the
    # rollback below safely delete the partial workspace it creates.
    if test -e "$ws_dir"
        echo >&2 "$(status filename): workspace dir '$ws_dir' already exists — remove or rename it, then retry."
        return 1
    end
    # A custom base may not exist yet (first workspace under it).
    mkdir -p (path dirname $ws_dir)
    or return 1

    set savepoint (__savepoint)
    and begin
        jj new --no-edit -A 'default@- & fork_point(default@-)' -B default@ -m "start $name"
        and jj bookmark create $name -r default@-
        and jj workspace add "$ws_dir" -r $name
        or begin
            __rollback $savepoint
            # op restore drops the workspace from jj's view but leaves the dir
            # `workspace add` created; it wasn't there before, so remove it.
            rm -rf "$ws_dir"
            return 1
        end
    end
    # The jj structure is committed; now hang the shared dirs off the new
    # workspace. A provisioning failure leaves a valid-but-bare workspace — op
    # restore can't undo symlinks/generated files anyway, so don't roll back.
    and __provision_ws "$ws_dir"
end

# `claim TODO` spins up a fresh workspace + claim for TODO (the common path).
# `claim TODO... --into NAME` instead folds each TODO into the EXISTING workspace
# NAME's claim, so one workspace can own several tickets. Without --into it is exactly
# the old single-todo behavior.
function __workflow_claim
    # -S/--strict-longopts: no abbreviation — only the exact `--into` is accepted, so a
    # typo like `--in` errors loudly instead of silently standing in for `--into`.
    argparse -S 'into=' or-start -- $argv
    or return
    if set -q _flag_into
        if set -q _flag_or_start
            echo >&2 "$(status filename): --or-start and --into don't combine."
            return 2
        end
        __workflow_adopt "$_flag_into" $argv
        or return
        echo >&2 "$(status filename): folded "(string join ', ' $argv)" into $_flag_into's claim. Its workspace is now stale — run 'jj workspace update-stale' there (commit first) before the next commit."
    else
        # One workspace per TODO on this path — extra TODOs would be silently
        # dropped by __workflow_start (it reads only $argv[1]). Refuse instead.
        if set -q argv[2]
            echo >&2 "$(status filename): 'claim' without --into starts ONE workspace for ONE todo — claim them one at a time, or fold extras into an existing workspace with 'claim TODO... --into NAME'."
            return 2
        end
        # --or-start (the EnterWorktree hook's mode): claim when NAME names a
        # claimable ticket/census row, else fall back to an ad-hoc start. A
        # wip/done NAME falls back too — start refuses on its own if the
        # workspace or dir already exists.
        if set -q _flag_or_start; and not contains -- (__ticket_state $argv[1]) triage census
            __workflow_start $argv
        else
            __claim_fresh $argv[1]
        end
    end
end

# claim TODO (fresh): one lock-held composition of the two primitives — start an
# empty-claim workspace, adopt TODO's ticket-move into the claim, heal the
# transient staleness the adopt squash leaves on the brand-new workspace. All-or-
# nothing: any failure rewinds past the start too, so no half-claimed workspace
# survives.
function __claim_fresh --argument-names name
    set -l savepoint (__savepoint)
    or return
    __workflow_start "$name"
    or return
    set -l ws_dir (jj workspace root --name "$name")
    __workflow_adopt "$name" "$name"
    # Keep the historical surface: a ticketed claim reads "claim NAME" in the
    # log, not "start NAME". Before the heal — describe rewrites the claim too.
    and jj describe -r "$name" -m "claim $name"
    and command jj -R "$ws_dir" workspace update-stale >/dev/null 2>&1
    # The adopt MUST leave the ticket move in the claim commit; empty here means
    # a concurrent op on default ate the snapshot — retry rather than keep an
    # empty claim posing as a ticketed one.
    and begin
        not jj log --no-graph -r "$name" -T 'empty' --ignore-working-copy | string match -q true
        or begin
            echo >&2 "$(status filename): $name's claim commit is empty — the ticket move was lost (a concurrent op on default). Nothing kept; re-run 'claim $name'."
            false
        end
    end
    or begin
        __rollback $savepoint
        rm -rf "$ws_dir"
        return 1
    end
end

# Fold TODOs' ticket-moves into NAME's existing claim commit, so one workspace
# owns several tickets. Runs from default (the claim is immutable elsewhere).
# Each ticket moves triage/->wip/ in default@ (via __claim_todo — same rules and
# census-mint as a normal claim), then ONLY those paths are squashed into the
# claim, so default@'s unrelated in-flight strays stay put. `drop` reverts the
# folded moves for free; `integrate` finishes them all. Leaves NAME's workspace
# stale — routine; one `workspace update-stale` there (commit first) clears it.
# Callers own the messaging/healing: `claim --into` warns, `__claim_fresh` heals.
function __workflow_adopt
    set -l into $argv[1]
    set -l tickets $argv[2..]
    set -l tdir "$project_dir/docs/tickets"

    if not set -q tickets[1]
        echo >&2 "$(status filename): 'claim --into $into' needs at least one TODO to fold in."
        return 2
    end
    # NAME must be a live feature: a workspace to own the tickets, and a claim commit
    # (its bookmark) to amend. An ad-hoc `start`ed NAME has both too.
    set -l ws_dir (jj workspace root --name "$into")
    or return
    if not jj bookmark list -T 'name ++ "\n"' | string match -q -- "$into"
        echo >&2 "$(status filename): no claim bookmark '$into' to fold into (is it a live workspace?)."
        return 1
    end

    set -l savepoint (__savepoint)
    or return
    begin
        # Collect the exact paths to squash: the new wip/ path always, plus the
        # old triage path — captured BEFORE __claim_todo moves the file.
        set -l paths
        set -l ok 1
        for t in $tickets
            set -l old (__ticket_triage_path $t)
            and set -a paths $old
            if not __claim_todo $t
                set ok 0
                break
            end
            set -a paths "$tdir/wip/$t.md"
        end
        # The bookmark follows the rewrite; default's line and NAME's WC are
        # rebased (the WC goes stale). Unrelated strays stay uncommitted in @.
        test $ok -eq 1
        and jj squash --from @ --into "$into" $paths
    end
    or begin
        __rollback $savepoint
        return 1
    end

end

# The un-integrated-work probe, shared by the single-workspace gate and the
# --integrated sweep so both judge "safe to drop?" identically. Prints the
# non-empty commits in default@..NAME@ (empty output = clean, nothing to lose).
# Callers MUST snapshot NAME first (see __snapshot_one) — this reads with
# --ignore-working-copy and would otherwise miss edits since NAME's last command.
function __unintegrated_work --argument-names name
    jj log --no-graph -r "(default@..$name@) ~ empty()" -T 'change_id.short() ++ " "' --ignore-working-copy 2>/dev/null
end

# Bank NAME's on-disk edits into its WC commit so a later --ignore-working-copy
# read sees them. Non-zero if the workspace can't be read.
function __snapshot_one --argument-names ws_dir
    command jj -R "$ws_dir" workspace update-stale >/dev/null 2>&1
    command jj -R "$ws_dir" status >/dev/null
end

# Name of the workspace this command runs FROM — matches its root against each
# per-name root. Empty if unresolvable. Lets the sweep never delete its own cwd.
function __current_workspace_name
    set -l here (jj workspace root 2>/dev/null)
    or return 1
    for n in (jj workspace list -T 'name ++ "\n"' --ignore-working-copy 2>/dev/null)
        test "$(jj workspace root --name $n 2>/dev/null)" = "$here"
        and begin
            echo $n
            return 0
        end
    end
    return 1
end

function __workflow_drop
    argparse -S force integrated dry-run -- $argv
    or return 2

    if set -q _flag_integrated
        if set -q _flag_force
            echo >&2 "$(status filename): --integrated never force-drops — it only sweeps already-integrated, empty workspaces. Target one explicitly with `drop --force NAME`."
            return 2
        end
        if set -q argv[1]
            echo >&2 "$(status filename): `drop --integrated` sweeps every integrated workspace — don't pass a NAME."
            return 2
        end
        if set -q _flag_dry_run
            __drop_sweep --dry-run
        else
            __drop_sweep
        end
        return
    end

    if set -q _flag_dry_run
        echo >&2 "$(status filename): --dry-run only applies to `drop --integrated`."
        return 2
    end

    set -l name $argv[1]
    if test -z "$name"
        echo >&2 "$(status filename): a workspace NAME is required (or `drop --integrated` to sweep integrated ones)."
        return 2
    end
    set -l ws_dir (jj workspace root --name "$name")
    or return

    # Plain drop (no --force) only removes what is already banked in trunk (integrated)
    # or worthless (nothing but empty commits — an untouched ad-hoc workspace). Anything
    # with real changes needs `integrate`, or an explicit --force. Snapshot NAME first:
    # __unintegrated_work reads --ignore-working-copy and would miss unsaved edits.
    if not set -q _flag_force
        __snapshot_one "$ws_dir"
        or return 1
        if test -n "$(__unintegrated_work $name)"
            # The claim bookmark doubles as the "not yet integrated" marker.
            if test -n "$(jj log --no-graph -r "bookmarks(exact:\"$name\")" -T 'change_id.short()' --ignore-working-copy 2>/dev/null)"
                echo >&2 "$(status filename): $name has un-integrated work (its claim bookmark still exists). Run `integrate $name` first, or `drop --force $name` to discard it."
            else
                echo >&2 "$(status filename): $name has new work since its last integrate. Integrate again, or `drop --force $name` to discard it."
            end
            return 2
        end
    end

    __drop_one "$name" "$ws_dir"
end

# Remove ONE workspace: forget it, abandon its claim + captured stack, delete its
# dir. Assumes the caller already cleared it as safe (integrated/empty) or is
# force-dropping. Snapshots every workspace first so the default-line rewrite below
# never rebases a stale sibling WC.
function __drop_one --argument-names name ws_dir
    __snapshot_workspaces
    # Resolve the claim exactly — a bare `-r "$name"` would also match a same-named
    # tag or substring. Its ABSENCE is what marks NAME already integrated.
    set -l claim (jj log --no-graph -r "bookmarks(exact:\"$name\")" -T 'change_id.short()' --ignore-working-copy 2>/dev/null)

    # Capture the doomed stack — exactly `default@..$name@` (everything on
    # NAME's side of the coordinator, the same set the refusal gate reads)
    # by change id, BEFORE workspace-forget dissolves $name@. Never append
    # `::` to it: descendants are not necessarily ours — integrate reorders
    # and stale-WC recovery can stack foreign claims/commits above a feature,
    # and the old unbounded `roots()::` sweep followed them into two other
    # features' work (2026-07-16). A commit of ours that escapes this bound
    # (a side fork off the stack, outside $name@'s ancestry) survives as
    # recoverable debris instead of foreign work being destroyed — the safe
    # failure direction.
    set stack (jj log --no-graph -r "default@..$name@" -T 'change_id.short() ++ "\n"' --ignore-working-copy)
    or begin
        echo >&2 "$(status filename): could not resolve $name@'s stack."
        return 1
    end

    set savepoint (__savepoint)
    and begin
        # Abandon the claim AND the captured stack; default's line just reparents
        # onto the claim's parent. workspace-forget runs first and drops the empty
        # trailing WC — for a fresh claim that WC *is* the whole stack — so keep
        # just the members that still resolve.
        jj workspace forget "$name"
        and begin
            test -z "$claim"; or jj bookmark forget "$name"
        end
        and begin
            set -l live
            for r in $stack
                jj log --no-graph -r "$r" --ignore-working-copy >/dev/null 2>&1
                and set -a live $r
            end
            # Post-integrate there may be nothing left to abandon: no claim, and
            # workspace-forget already dropped the empty WC. A bare `jj abandon`
            # would target default's @ — skip instead.
            if test -n "$claim"; or set -q live[1]
                jj abandon $claim $live
            end
        end
        or begin
            __rollback $savepoint
            return 1
        end
    end
    # The commits stay recoverable via the op log until gc; the dir is just a
    # checkout copy plus build junk — delete it outright, no archive.
    and rm -rf "$ws_dir"
end

# `drop --integrated`: sweep every integrated (claim bookmark gone), empty feature
# workspace — the routine post-integrate cleanup agents forget to run. NEVER touches
# `default`, the workspace you run FROM, an un-integrated one (bookmark still there),
# or an integrated one someone resumed work in. --dry-run reports the same verdicts
# and deletes nothing. Runs under the same workflow lock as a plain drop (the whole
# sweep is one locked op), so its per-workspace drops don't race other lifecycle ops.
function __drop_sweep
    argparse -S dry-run -- $argv
    or return 2
    set -l current (__current_workspace_name)
    set -l dropped
    set -l kept
    set -l failed
    for name in (jj workspace list -T 'name ++ "\n"' --ignore-working-copy 2>/dev/null)
        test "$name" = default; and continue
        test "$name" = "$current"; and continue
        # Still holds a claim bookmark → not integrated yet → leave it alone.
        test -z "$(jj log --no-graph -r "bookmarks(exact:\"$name\")" -T 'change_id.short()' --ignore-working-copy 2>/dev/null)"
        or continue
        set -l ws_dir (jj workspace root --name "$name")
        or continue
        # Snapshot, then keep any integrated workspace that has since gained work. A
        # snapshot failure counts as "unsafe" — keep it; never sweep on a blind read.
        __snapshot_one "$ws_dir"
        set -l snap_ok $status
        if test $snap_ok -ne 0; or test -n "$(__unintegrated_work $name)"
            set -a kept "$name"
            continue
        end
        if set -q _flag_dry_run
            set -a dropped "$name"
            continue
        end
        if __drop_one "$name" "$ws_dir"
            set -a dropped "$name"
        else
            set -a failed "$name"
        end
    end

    set -l verb dropped
    set -q _flag_dry_run; and set verb "would drop"
    if set -q dropped[1]
        echo >&2 "$(status filename): $verb "(count $dropped)" integrated workspace(s): $dropped"
    else
        echo >&2 "$(status filename): no integrated workspaces to drop."
    end
    if set -q kept[1]
        echo >&2 "$(status filename): kept "(count $kept)" workspace(s) with work since integrate: $kept"
    end
    if set -q failed[1]
        echo >&2 "$(status filename): FAILED to drop: $failed"
        return 1
    end
    return 0
end

# refresh, keyed on where it runs:
#   • feature workspace, no arg (the common case) — DETACH: rebase the stack onto
#     the trunk tip (default@-), separating it from its claim (integrate re-joins).
#   • default with a name — REORDER: slide the claim to just under default@,
#     feature carried along; --all reorders every workspace this way (push prep).
# Both bring the feature current with trunk; they differ only in topology. --all
# stops at the first conflict (69) or failure (1) and propagates its status.
# Refreshing an already-current feature is a harmless no-op either way.
function __workflow_refresh
    # -S: never abbreviate --all (standing rule — exact long opts only).
    argparse -S a/all -- $argv
    or return

    set -l on_default (test "$project_dir" = "$(path resolve (jj workspace root --name default))"; and echo 1)

    if set -q _flag_all
        if set -q argv[1]
            echo >&2 "$(status filename): 'refresh --all' takes no WORKSPACE name (got '$argv[1]')."
            return 2
        end
        # Reorder rewrites default's shared line — it must hold DEFAULT's lock. From
        # a feature workspace this run re-exec'd under that workspace's private lock,
        # which serializes against nothing that touches default.
        if test -z "$on_default"
            echo >&2 "$(status filename): 'refresh --all' rewrites default's shared line — run it from the default workspace."
            return 2
        end
        # Every workspace but the default coordinator, in jj's (alphabetical) order.
        set -l targets
        for ws in (jj workspace list -T 'name ++ "\n"')
            test "$ws" = default; or set -a targets "$ws"
        end
        if not set -q targets[1]
            echo >&2 "$(status filename): no non-default workspaces to refresh."
            return 0
        end
        __snapshot_workspaces
        for ws in $targets
            echo >&2 "$(status filename): refreshing $ws"
            __refresh_reorder "$ws"; or return    # stop at the first conflict/failure
        end
        echo >&2 "$(status filename): refreshed "(count $targets)" workspace(s): "(string join ', ' $targets)"."
        return 0
    end

    set -l name $argv[1]
    if test -z "$name"
        # No name → detach the workspace we're standing in. NB: `test -n`, not
        # `set -q` — the var is always DEFINED (empty off-default), and `set -q`
        # on a defined-but-empty local is true.
        if test -n "$on_default"
            echo >&2 "$(status filename): refresh needs a WORKSPACE name (or --all), or run it from a feature workspace."
            return 2
        end
        __refresh_detach (path basename $project_dir)
    else if test -n "$on_default"
        # From default with a name → the old reorder-under-default@.
        __snapshot_workspaces
        __refresh_reorder "$name"
    else
        # From a feature workspace with an explicit name — ONLY its own: this run's
        # flock is the INVOKING workspace's, so detaching another feature's stack
        # from here would race that workspace's own refresh/integrate unserialized.
        # (Basename == workspace name holds for toolkit-created feature workspaces.)
        if test "$name" != (path basename $project_dir)
            echo >&2 "$(status filename): refresh '$name' from the default workspace (reorder), or run a no-arg refresh inside $name's own workspace (detach) — refreshing it from here would hold the wrong lock."
            return 2
        end
        __refresh_detach "$name"
    end
end

# DETACH (from a feature workspace, and from integrate): rebase $name's stack —
# everything $name@ has that default@ lacks — onto the trunk tip (default@-),
# separating it from its claim (which stays in default's line; integrate re-joins
# it). A single atomic rebase, so no op-log rollback is needed; idempotent.
# Returns 69 (conflict left in place) or 1 (failed).
function __refresh_detach
    set name $argv[1]
    # P1: refuse before touching anything if the trunk tip we'd rebase onto
    # (default@-) is a merge — an ambiguous anchor the coordinator must resolve.
    __require_linear_trunk; or return
    set ws_dir (jj workspace root --name "$name"); or return 1
    # Empty stack → already fully in default@'s ancestry; `jj rebase` errors on
    # an empty -r set, so short-circuit (still clearing staleness). A FAILED log
    # must be a hard error, not "nothing to refresh" — `set` keeps the
    # substitution's status, unlike the old unquoted `test -z (…)`.
    set -l stack (jj log --no-graph -r "default@..$name@" -T 'change_id.short()' --ignore-working-copy)
    or return 1
    if test -z "$stack"
        command jj -R "$ws_dir" workspace update-stale >/dev/null 2>&1
        return 0
    end

    jj rebase -r "default@..$name@" -d 'default@-'
    or return 1
    # A conflicted rebase exits 0; capture it, then clear the staleness the
    # rebase left (a no-op when run from $name's own workspace). An update-stale
    # failure with NO conflict is a real problem (e.g. divergence) — surface it.
    set -l conflicted (jj log --no-graph -r "default@..$name@ & conflicts()" -T 'change_id.short() ++ "\n"' --ignore-working-copy)
    command jj -R "$ws_dir" workspace update-stale
    or test -n "$conflicted"; or return 1
    if test -n "$conflicted"
        echo >&2 "$(status filename): $name now conflicts with the trunk tip — resolve it in $ws_dir, then re-run."
        return 69
    end
end

# REORDER (from default): slide $name's claim to sit just under default@,
# feature stack and workspace WC carried along. Rewrites default's shared line,
# so it runs under default's lock. Returns 69 (conflict left) or 1 (rolled back).
function __refresh_reorder
    set name $argv[1]
    set ws_dir (jj workspace root --name "$name"); or return 1
    # Feature-stack root (a detached stack is re-attached by the reorder below).
    # Capture it before the move — its change id survives the rebase even though
    # the commit id won't.
    set root (__feature_roots "$name"); or return 1
    if not set -q root[1]
        echo >&2 "$(status filename): could not locate $name's feature root."
        return 1
    end
    if set -q root[2]
        echo >&2 "$(status filename): $name's stack has multiple roots — reorder can't carry it in one piece; integrate it, or simplify the stack by hand."
        return 1
    end

    set savepoint (__savepoint)
    and begin
        # -r pulls the claim out of the chain (healing the gap) and --insert-before
        # threads it back in just under default@.
        jj rebase -r "$name" --insert-before default@
        # -r reparented the claim's children — including the feature stack — onto its old
        # parent; pull the feature stack back onto the moved claim commit.
        and jj rebase -s "$root" -d "$name"
        and command jj -R "$ws_dir" workspace update-stale
        or begin
            __rollback $savepoint
            return 1
        end
    end

    __conflict_stop "$root::" "$ws_dir" "$name now conflicts with default@"
end

function __integrate_steps
    set name $argv[1]
    set -l ws_dir (jj workspace root --name "$name"); or return
    # Snapshot NAME's on-disk working copy first: every read below runs from
    # default with --ignore-working-copy, so edits after the agent's last jj
    # command would otherwise be invisible to the in-flight-work checks below.
    # update-stale first so a stale workspace (e.g. after `claim --into`)
    # doesn't fail the snapshot.
    command jj -R "$ws_dir" workspace update-stale >/dev/null 2>&1
    command jj -R "$ws_dir" status >/dev/null
    or return 1
    # Refresh first — always the DETACH path, so the re-join below has a detached
    # feature to thread the claim back into, and the fold never rewinds default@
    # past newer trunk work. 69 = a conflict was left in the workspace: bail with
    # the same sentinel, no fold, no rollback.
    __refresh_detach "$name"
    or return

    # Re-join the claim under the now-current feature at its fork point,
    # rebuilding the "claim under default@, feature branching off it" shape the
    # fold relies on — but only when actually DETACHED: after a no-op refresh the
    # feature still sits ON its claim and `rebase -r NAME -A NAME` would be a
    # cycle. This guard is what makes refresh+rejoin idempotent across re-runs.
    set -l fork_parent (jj log --no-graph -r "fork_point(default@..$name@)-" -T 'change_id.short()' --ignore-working-copy)
    set -l claim_cid (jj log --no-graph -r "$name" -T 'change_id.short()' --ignore-working-copy)
    if test -n "$fork_parent" -a "$fork_parent" != "$claim_cid"
        jj rebase -r "$name" -A "fork_point(default@..$name@)-"
        or return 1
        # The re-join reparented the feature stack onto the claim → the workspace WC is
        # now stale; clear it before the inspection / cap below touch the workspace.
        command jj -R "$ws_dir" workspace update-stale >/dev/null 2>&1
        # As with refresh, a re-join conflict (the claim's ticket-move vs. trunk) is
        # recorded and exits 0. Leave it for the workspace to resolve; bail 69, no fold.
        __conflict_stop "$name::" "$ws_dir" "re-joining $name's claim conflicts with the trunk tip"
        or return
    end

    # Inspect the workspace's working-copy commit. A clean hand-off has emptiness
    # and describedness AGREEing: either an empty undescribed @ (the agent ended on
    # `jj new`), or the finished work sitting in @ described-but-not-`new` (a common
    # habit). When they DISAGREE it's work in flight — stop (69), don't fold:
    #   - empty + described  -> a set-up-but-unfilled commit; looks in-progress.
    #   - nonempty + undescribed -> uncommitted/undescribed work.
    set -l wc_empty (jj log --no-graph -r "$name"@ -T 'if(empty, "y", "")' --ignore-working-copy)
    set -l wc_desc (jj log --no-graph -r "$name"@ -T 'if(description, "y", "")' --ignore-working-copy)
    if test -n "$wc_empty" -a -n "$wc_desc"
        echo >&2 "$(status filename): $name@ is described but empty — that reads as work in progress. Finish it, or clear the description / abandon it, then re-integrate."
        return 69
    else if test -z "$wc_empty" -a -z "$wc_desc"
        echo >&2 "$(status filename): $name has undescribed work in its workspace — describe it (jj describe -m …) or abandon it, then re-integrate."
        return 69
    else if test -z "$wc_empty" -a -n "$wc_desc"
        # Finished work left AS the working copy: cap it with a fresh empty
        # commit so the work becomes $name@- and the fold picks it up — exactly
        # as if the agent had run `jj new` themselves.
        command jj -R "$ws_dir" new
        or begin
            echo >&2 "$(status filename): couldn't cap $name's described work with an empty commit."
            return 1
        end
    end
    # else: empty + undescribed — already the clean trailing-commit shape.

    # Fold: move default's @ onto the feature tip, finish the todo as the final
    # commit. Nothing here is irreversible — every fail-able step rolls back via
    # the op-log savepoint. Capture the workspace's WC by change id: it survives
    # integrate and gets re-parked on the new trunk tip at the end.
    set -l ws_wc (jj log --no-graph -r "$name"@ -T 'change_id.short()')
    # The tickets this claim owns = the wip/ files its claim commit adds (one,
    # several after `claim --into`, none for an ad-hoc `start`) — read off the
    # claim's own diff so a multi-ticket claim finishes them ALL. jj prints diff
    # paths relative to CWD, so anchor at the workspace root.
    set -l prev_pwd "$PWD"
    cd "$project_dir"
    set -l slugs
    for p in (jj diff -r "$name" --name-only --ignore-working-copy)
        set -l s (string match -rg '^docs/tickets/wip/(.+)\.md$' -- $p)
        test -n "$s"; and set -a slugs $s
    end
    cd "$prev_pwd"
    # Naming the wip+done pair per ticket scopes the completion commit to ONLY
    # the ticket moves — default@ routinely carries unrelated in-flight edits,
    # and a bare `jj commit` would sweep those strays into "complete …" (exactly
    # how a concurrent integrate once swallowed an unrelated edit).
    set -l move_paths
    for s in $slugs
        set -a move_paths "$project_dir/docs/tickets/wip/$s.md" "$project_dir/docs/tickets/done/$s.md"
    end

    jj rebase -r @ -d "$name"@-
    # Unlike refresh/re-join conflicts (left in the feature workspace as 69), a
    # fold conflict sits on default@ ITSELF — proceeding would retire the
    # workspace around a permanently conflicted trunk tip. Fail (1) → rollback.
    and begin
        set -l fold_conflict (jj log --no-graph -r '@ & conflicts()' -T 'change_id.short()' --ignore-working-copy)
        test -z "$fold_conflict"
        or begin
            echo >&2 "$(status filename): folding default@ onto $name's tip conflicts — rolling back; commit or clear default@'s in-flight edits, then re-integrate."
            false
        end
    end
    and __check_todo $slugs
    and if set -q slugs[1]
        jj commit -m "complete $(string join ' ' $slugs)" $move_paths
    end
    # Drop the now-folded claim bookmark: its commit lives on in default@'s
    # history, and the bookmark's ABSENCE is what tells a later plain `drop`
    # this workspace is integrated and safe to remove.
    and jj bookmark forget "$name"
    # An ad-hoc claim that never adopted a ticket is an EMPTY link in the
    # integrated chain — elide it so trunk history carries only real work.
    # ($claim_cid is a change id, stable across the rejoin/fold rewrites;
    # ticketed claims are non-empty by construction, and abandoning an empty
    # commit cannot conflict.)
    and begin
        not jj log --no-graph -r "$claim_cid" -T 'empty' --ignore-working-copy | string match -q true
        or jj abandon -r "$claim_cid"
    end
    # KEEP the workspace — park its WC as a fresh empty change on the new trunk
    # tip (a no-op when no completion commit ran, since the fold left it there).
    # The workspace stays usable for follow-up work; `drop NAME` retires it.
    and jj rebase -r "$ws_wc" -d @-
end

function __workflow_integrate
    set name $argv[1]
    set ws_dir (jj workspace root --name "$name")
    or return
    __snapshot_workspaces

    set savepoint (__savepoint)
    or return

    __integrate_steps "$name"
    switch $status
        case 0
            # Work folded into default@. The workspace survives with its WC
            # parked on the integrated tip; its on-disk pointer was rewritten
            # under it, so clear the staleness before anyone works there.
            command jj -R "$ws_dir" workspace update-stale >/dev/null 2>&1
            echo >&2 "integrated $name — retire its workspace now (default next step): workflow drop $name   (or keep $ws_dir to resume follow-up work there)"
            return 0
        case 69
            # Expected stop (conflict or uncommitted work) — state left in place for
            # the user to resolve. Do NOT roll back.
            return
        case '*'
            __rollback $savepoint
            return 1
    end
end

# Heal a working-copy divergence (two+ commits sharing @'s change id) in ONE
# pass: keep the half holding your work (the non-empty one), drop the rest.
# REFUSES when two halves hold genuinely different non-empty work — resolve by
# hand. Run FROM the affected feature workspace.
function __workflow_converge
    jj workspace update-stale 2>/dev/null    # clear staleness first; safe under the guards
    set -l cid (jj log --no-graph --ignore-working-copy -r @ -T 'change_id')
    # One query for every half: commit id + emptiness per line. The work lives
    # in the non-empty half; identify by content, never by /N index.
    set -l commits
    set -l nonempty
    for line in (jj log --no-graph --ignore-working-copy -r "change_id($cid)" \
        -T 'commit_id.short() ++ " " ++ empty ++ "\n"')
        set -l c (string split ' ' -- $line)
        set -a commits $c[1]
        test "$c[2]" = true; or set -a nonempty $c[1]
    end
    if test (count $commits) -le 1
        echo "converge: @ is not divergent — nothing to do."
        return 0
    end
    set -l keep
    switch (count $nonempty)
        case 0
            set keep $commits[1]   # all empty → identical; keep any
        case 1
            set keep $nonempty[1]  # one real half + empty placeholder(s)
        case '*'
            set keep $nonempty[1]  # multiple non-empty: only safe if byte-identical
            for c in $nonempty[2..]
                if test -n "$(jj diff --ignore-working-copy --from $keep --to $c)"
                    echo >&2 "converge: divergent halves hold DIFFERENT work ($keep vs $c) — resolve by hand (jj edit the right one, jj abandon the others)."
                    return 1
                end
            end
    end
    set -l drop
    for c in $commits
        test "$c" = "$keep"; or set -a drop $c
    end
    # Make the keeper @, then drop the rest. Editing the keeper may auto-hide the
    # empty half, so a "nothing to abandon" here is success, not failure.
    jj edit $keep
    or return 1
    jj abandon $drop 2>/dev/null
    echo "converge: kept $keep, dropped: $drop"
end

# Walk a feature stack's conflicts oldest-first IN PLACE, from the feature
# workspace: each run drops you onto a conflicted commit (exit 1); remove its
# markers (`jj st` lists the files); re-run to fold the fix and move on. Exit 0 =
# stack clean, re-integrate. Exit 2 = markers left, or a jj step rolled back.
# The `$name-tip` bookmark is the cursor marking the real tip during the
# descent. For a working-copy DIVERGENCE use `converge` instead.
function __workflow_resolve
    # Dir basename == workspace name holds for toolkit-created FEATURE
    # workspaces, and resolve's contract is to run from one.
    set -l name (path basename $project_dir)
    set -l tipbm "$name-tip"
    set -l savepoint (__savepoint)

    # Mid-descent: the cursor exists, so @ is your edit of one conflicted commit.
    if jj bookmark list -T 'name ++ "\n"' | string match -q -- "$tipbm"
        if jj resolve --list >/dev/null 2>&1   # exit 0 => @ still has conflicts
            echo >&2 "resolve: @ still has conflict markers — remove them all (jj st lists the files), then re-run."
            return 2
        end
        # Fold @'s resolution into the commit it sits on, then hop to the real tip
        # so the scan below spans the whole stack.
        begin
            if test -n "$(jj log -G -r '@- & conflicts()')"
                jj squash
            end
        end
        and jj edit "$tipbm"
        and jj bookmark forget "$tipbm"
        or begin
            echo >&2 "resolve: a jj step failed — rolled back. Resolve by hand or ask for help."
            jj op restore "$savepoint"
            return 2
        end
    end

    # Remaining conflicts in this feature's stack (oldest last; jj lists newest-first).
    set -l conflicts (jj log -G -r "$name+::@ & conflicts()" -T 'change_id.short() ++ "\n"')
    if set -q conflicts[1]
        begin
            jj bookmark create "$tipbm"
            and jj new $conflicts[-1]
        end
        or begin
            echo >&2 "resolve: a jj step failed — rolled back. Resolve by hand or ask for help."
            jj op restore "$savepoint"
            return 2
        end
        echo >&2 "resolve: editing the oldest of "(count $conflicts)" conflicted commit(s). Remove all markers (jj st), then re-run resolve."
        return 1
    else
        echo >&2 "resolve: all conflicts resolved on $name@ — re-run 'scripts/workflow integrate $name'."
        return 0
    end
end

# One-stop recovery for "my branch shifted under me", run FROM the feature
# workspace: update-stale, converge (if divergent), resolve (if conflicted).
# Exit 0 = clean (re-integrate); 1 = on a conflicted commit, remove its markers
# and re-run; 2 = a human is needed.
function __workflow_repair
    set -l name (path basename $project_dir)
    # Clear a stale working copy — that's what surfaces a divergence or conflicts.
    jj workspace update-stale 2>/dev/null
    set -l div (jj log -G -r "$name::$name@ & divergent()")
    if test -n "$div"
        __workflow_converge
        or begin
            echo >&2 "repair: the two divergent halves hold genuinely different work — a human is needed."
            return 2
        end
    end
    set -l conf (jj log -G -r "$name::$name@ & conflicts()")
    if test -z "$conf"
        echo >&2 "repair: branch clean — carry on (re-integrate if you were mid-integrate)."
        return 0
    end
    # Let resolve do the walking, but keep its (and jj's) chatter quiet — repair
    # owns the conflict output below, including the file list.
    __workflow_resolve >/dev/null 2>&1
    set -l rc $status
    switch $rc
        case 0
            echo >&2 "repair: conflicts resolved — branch clean, re-integrate."
        case 1
            echo >&2 "repair: stopped on a conflict. For each file above, resolve with:"
            echo >&2 "    scripts/conflicts accept FILE stack          (both sides added — stack them)"
            echo >&2 "    scripts/conflicts accept FILE snapshot|diff  (pick one side)"
            echo >&2 "    [edit FILE directly]                         (complex/semantic conflict)"
            echo >&2 "Then re-run 'scripts/workflow repair'."
            echo >&2 ""
            for f in (jj resolve --list 2>/dev/null | string replace -r '\s.*$' '')
                echo >&2 "    $f"
            end
            echo >&2 ""
            $scripts_dir/conflicts show >&2
        case '*'
            echo >&2 "repair: stopped (exit $rc) — finish removing markers and re-run, or get a human if jj rolled back."
    end
    return $rc
end

# Serialize the transactional commands: two sessions sharing default@ must not
# interleave jj ops (corrupted op log, ticket moves raced out of claim commits).
# The lockfile lives in the INVOKING workspace's .jj/ (never snapshotted), which
# lands exactly right: from-default runs take default's lock, while a
# from-workspace no-arg refresh — which only rewrites its own isolated stack —
# takes its own uncontended lock, so an agent never waits to refresh.
# repair/converge/resolve are deliberately lock-free. The re-exec puts the WHOLE
# operation (every jj step plus rollback) under one flock, released by the
# kernel when the process exits — even on a crash. _WORKFLOW_LOCKED breaks the
# re-exec recursion.
if not set -q _WORKFLOW_LOCKED; and contains -- "$argv[1]" claim start drop refresh integrate
    set -gx _WORKFLOW_LOCKED 1
    # -w 600: wait up to 10 min (a held lock spans one op, incl. claim/start's slow
    # workspace provisioning) rather than failing fast under contention. -E 75: on
    # timeout exit 75, distinct from the command's own codes (incl. 2), so a genuine
    # "couldn't acquire" is never mistaken for the operation's result.
    flock -w 600 -E 75 "$project_dir/.jj/workflow.lock" "$scripts_dir/workflow" $argv
    set -l rc $status
    if test $rc -eq 75
        echo >&2 "$(status filename): timed out waiting for the workflow lock — another claim/start/drop/refresh/integrate is holding it. Re-run once it finishes."
        return 1
    end
    return $rc
end

switch $argv[1]
    case claim
        __workflow_claim $argv[2..]
    case start
        __workflow_start $argv[2..]
    case drop
        __workflow_drop $argv[2..]
    case integrate
        __workflow_integrate $argv[2..]
    case refresh
        __workflow_refresh $argv[2..]
    case repair
        __workflow_repair
    case converge
        __workflow_converge
    case resolve
        __workflow_resolve
    case '*'
        __workflow_usage
end
set -l rc $status
test $rc -eq 69; and return 2
return $rc
