#!/usr/bin/env fish

source (status dirname)/lib/setup.fish jj flock
or return

# Every jj call below resolves its workspace from CWD, while $project_dir (the
# lock file, ticket paths) comes from this script copy's location. A sibling-path
# invocation (`../other/scripts/workflow …`) would silently operate on the CWD
# workspace under the OTHER workspace's lock — refuse the mismatch.
set -l __cwd_ws (jj workspace root 2>/dev/null)
if test -z "$__cwd_ws"; or test "$(path resolve $__cwd_ws)" != "$project_dir"
    echo >&2 "$(status filename): CWD is in workspace '$__cwd_ws', but this copy belongs to $project_dir — run that workspace's own scripts/workflow from inside it."
    return 1
end

# Most commands run from default. The exceptions run IN the affected feature
# workspace: `repair`/`converge`/`resolve` heal staleness / divergence /
# refresh-conflicts there, and `refresh` (no-arg) rebases the current workspace's
# feature stack onto the trunk tip — all touch only the isolated feature, never
# default's shared line, so they're safe from any workspace.
if not contains -- "$argv[1]" repair converge resolve refresh; and test "$(jj workspace root)" != "$(jj workspace root --name default)"
    echo >&2 "$(status filename): intended to be run from default workspace only (except 'refresh'/'repair'/'converge'/'resolve')."
    return 1
end

function __workflow_usage
    echo >&2 "\
Usage: $(status filename) <command> [<args>]
  Commands:
    claim TODO           Claim a todo item and start a workspace named TODO.
    claim TODO... --into NAME
                         Fold each TODO into the EXISTING workspace NAME's claim
                         instead of starting a new workspace — NAME then owns those
                         tickets too, and `integrate NAME` finishes them all. Use this
                         to take on extra todos after a workspace is already going.
                         (NAME's workspace goes stale; run `workspace update-stale`
                         there.)
    start NAME           Spin up an ad-hoc workspace named NAME, with no todo to claim.
    abandon WORKSPACE    Abandon WORKSPACE and forget its todo claim.
    refresh [WORKSPACE]  From a feature workspace (no WORKSPACE): rebase its stack onto
                         the trunk tip (default@-), detaching it from its claim (integrate
                         re-joins). From default with a WORKSPACE: reorder that claim to
                         sit just under default@, feature carried along (the old behavior).
                         Always refresh before any review step.
    refresh --all        Reorder EVERY non-default workspace's claim under default@ (prep
                         for a push), stopping at the first that conflicts or fails.
    integrate WORKSPACE  Refresh, re-join the claim to the feature, fold WORKSPACE's
                         work into default@, then drop the workspace.
    repair               Run FROM a feature workspace: one-stop "my branch shifted under me"
                         recovery = update-stale + converge + resolve. Exit 0 clean; exit 1 fix
                         the conflict markers (jj st) and re-run; exit 2 needs a human.
    converge             Run FROM a feature workspace: heal a working-copy divergence left
                         by a concurrent op — keep the half holding your work, drop the rest.
    resolve              Run FROM a feature workspace to walk a refresh/integrate conflict one
                         commit at a time: drops you onto a conflict (exit 1); remove its
                         markers; re-run. Exit 0 once the stack is clean.
"
    exit 2
end

if not set -q argv[1]
    __workflow_usage
end

# Claim NAME: move its ticket into wip/. From a triage folder (critical/planned/
# maybe) it's a rename; a census-only mechanic is minted fresh into wip/. The move
# or add lands in the claim commit, so `abandon` reverts it automatically. An
# already-claimed (wip/) or finished (done/) name, or an unknown one, fails the claim.
function __claim_todo
    set -l name $argv[1]
    set -l tickets "$project_dir/docs/tickets"
    # wip/ may be absent on disk: an empty directory isn't tracked, so a checkout with
    # nothing currently claimed materializes no wip/ for the move (or the census mint)
    # to land in — `mv`/redirect would fail with "No such file or directory". Ensure it.
    mkdir -p "$tickets/wip"
    or return
    for folder in critical planned maybe
        if test -f "$tickets/$folder/$name.md"
            mv "$tickets/$folder/$name.md" "$tickets/wip/$name.md"
            return                       # propagate mv's status — never mask a failure
        end
    end
    if test -f "$tickets/wip/$name.md"
        echo >&2 "$(status filename): '$name' is already claimed (in wip/)."
        return 1
    end
    if test -f "$tickets/done/$name.md"
        echo >&2 "$(status filename): '$name' is already done."
        return 1
    end
    # Not a ticket — mint a wip ticket only if NAME is a real census mechanic.
    if "$scripts_dir/todo" iscensus $name >/dev/null 2>&1
        "$scripts_dir/todo" mint $name >"$tickets/wip/$name.md"
        and test -s "$tickets/wip/$name.md"
        and return 0
        rm -f "$tickets/wip/$name.md"
        echo >&2 "$(status filename): minting '$name' from the census failed."
        return 1
    end
    echo >&2 "$(status filename): no ticket or census row named '$name'."
    return 1
end

# Finish each NAMED ticket: move its wip/ file -> done/. Tolerant — a name with no
# wip/ ticket (an ad-hoc `start`ed feature, or a slug already moved) is skipped, and
# an empty list is success (nothing to finish), not failure. integrate passes every
# ticket its claim commit owns: one for a plain claim, several after `claim --into`,
# none for an ad-hoc `start`.
function __check_todo
    set -l tickets "$project_dir/docs/tickets"
    set -q argv[1]; or return 0          # nothing to finish (ad-hoc / empty list)
    # done/ may not exist yet (empty dirs aren't tracked) — create it before any move.
    mkdir -p "$tickets/done"; or return
    for name in $argv
        test -f "$tickets/wip/$name.md"; or continue
        mv "$tickets/wip/$name.md" "$tickets/done/$name.md"; or return
    end
end

# jj's `git clean -fdX`, for a workspace about to be retired: delete every
# on-disk file jj does NOT track, then prune the directories that emptied.
# Under jj's default auto-tracking, snapshotting first (file list without
# --ignore-working-copy) makes untracked == gitignored, so nothing real is
# deleted — any non-ignored stray lands in @ (hence the op log) before the
# comparison. Must run while jj still knows the workspace: after `workspace
# forget` there is no tracked list to diff against. Best-effort by design (a
# failure means a fat archive, not a broken retire) — but an EMPTY tracked
# list aborts the clean: a real workspace tracks scripts/ at minimum, so empty
# means the listing failed, and deleting "everything untracked" would then
# mean everything.
function __clean_ignored --argument-names ws_dir
    command jj -R "$ws_dir" workspace update-stale >/dev/null 2>&1
    # jj prints paths relative to CWD — run from the workspace root so the
    # tracked list lines up with find's %P (both ws-relative, NUL-joinable).
    set -l prev_pwd "$PWD"
    cd "$ws_dir"; or return 0
    set -l tracked (command jj -R "$ws_dir" file list 2>/dev/null)
    cd "$prev_pwd"
    set -q tracked[1]; or return 0
    # Disk inventory via find, not fish globs (globs skip dotfiles, and junk
    # is often dot-prefixed). .jj/.git are workspace plumbing, never junk.
    set -l junk (comm -z -23 \
        (find "$ws_dir" -mindepth 1 \( -name .jj -o -name .git \) -prune -o \( -type f -o -type l \) -printf '%P\0' | sort -z | psub) \
        (printf '%s\0' $tracked | sort -z | psub) | string split0)
    if set -q junk[1]
        printf '%s\0' $ws_dir/$junk | xargs -0 -r rm -f --
    end
    # Prune dirs the deletions emptied, deepest first (a child sorts after its
    # parent, so the reverse sort visits it first); non-empty ones are kept.
    find "$ws_dir" -mindepth 1 \( -name .jj -o -name .git \) -prune -o -type d -print0 |
        sort -zr | xargs -0 -r rmdir --ignore-fail-on-non-empty -- 2>/dev/null
    return 0
end

# Create an archive bucket. On btrfs it's made a SUBVOLUME: excluded from
# snapshots of the parent volume, and droppable wholesale (`btrfs subvolume
# delete`, or empty it and rmdir where that needs root). Anything short of
# that — other filesystem, no btrfs CLI, creation refused — quietly degrades
# to a plain directory.
function __ensure_bucket --argument-names dest
    test -d "$dest"; and return 0
    if command -q btrfs; and test "$(stat -f -c %T (path dirname $dest) 2>/dev/null)" = btrfs
        btrfs subvolume create "$dest" >/dev/null 2>&1
        and return 0
    end
    mkdir -p "$dest"
end

# Retire a workspace dir into a sibling bucket instead of deleting it. Callers
# strip ignored/generated files first via __clean_ignored (it needs jj access,
# gone once the workspace is forgotten). Tracked symlinks into other workspaces
# may break (fine — gc the bucket later), but nothing tracked is destroyed.
function __retire_ws --argument-names ws_dir bucket
    test -d "$ws_dir"; or return 0
    set -l dest (path dirname $project_dir)/$bucket
    __ensure_bucket $dest
    set -l base (path basename $ws_dir)
    set -l target $dest/$base
    set -l n 1
    while test -e $target
        set target $dest/$base.$n
        set n (math $n + 1)
    end
    mv "$ws_dir" $target
end

# Read a flat `key = "value"` (or `key = value`) line from jjworkflow.toml, or
# echo DEFAULT. Deliberately dumb — no TOML parser dependency; flat keys only.
function __jjworkflow_config --argument-names key default
    set -l cfg $project_dir/jjworkflow.toml
    if test -f $cfg
        set -l val (string match -rg "^\s*$key\s*=\s*[\"']?([^\"'#]*?)[\"']?\s*(?:#.*)?\$" <$cfg)
        if test -n "$val"
            echo $val
            return
        end
    end
    echo $default
end

# Give a fresh workspace whatever gitignored/generated shared state the consuming
# project needs. `jj workspace add` only checks out tracked files, so projects
# hook in their own provisioning: an executable at $provision_hook (default
# scripts/provision-workspace) is run with the new workspace dir as $argv[1].
# No hook -> no-op (a pure-source project needs nothing).
function __provision_ws --argument-names ws_dir
    set -l hook (__jjworkflow_config provision_hook scripts/provision-workspace)
    set -l hook_path $project_dir/$hook
    if test -x "$hook_path"
        if not "$hook_path" "$ws_dir"
            echo >&2 "$(status filename): provision hook '$hook' failed for $ws_dir — finish provisioning by hand."
            return 1
        end
    end
end

# Spin up a NAME-bookmarked base commit on default@- with a ../NAME workspace on
# top, leaving default's @ put. With -t/--claim-todo, also tick NAME's todo box
# into the base commit (so abandoning the base reverts the tick automatically).
function __workflow_start
    argparse t/claim-todo -- $argv
    or return

    set name "$argv[1]"
    if test -z $name
        echo >&2 "$(status filename): a workspace NAME is required."
        return 2
    end
    if set -q argv[2]
        echo >&2 "$(status filename): expected exactly one NAME (got: $argv)."
        return 2
    end
    set ws_dir (path dirname $project_dir)/$name
    # Refuse a pre-existing dir up front: `jj workspace add` would fail mid-sequence
    # with a cryptic "destination exists", and knowing it's absent now lets the
    # rollback below safely delete the partial workspace it creates.
    if test -e "$ws_dir"
        echo >&2 "$(status filename): workspace dir '$ws_dir' already exists — remove or rename it, then retry."
        return 1
    end

    set -l verb start
    set -q _flag_claim_todo; and set verb claim

    set savepoint (jj op log -G -n1 -T 'id.short()')
    and begin
        jj bookmark create __tip
        and jj new @- -m "$verb $name"
        and jj bookmark create $name
        and if set -q _flag_claim_todo
            # Move the ticket into wip/, then snapshot it into the claim commit
            # right away. Until something snapshots it the move lives only in
            # default's working copy; the next op (`workspace add`) WOULD capture it,
            # but default is shared — pinning it now shrinks the gap in which a
            # concurrent op on default could swallow the move before it's committed.
            __claim_todo $name
            and jj status >/dev/null
        end
        and jj workspace add "$ws_dir" -r $name
        and jj rebase -r __tip -d $name
        and jj edit __tip
        and jj bookmark forget __tip
        # A claimed todo MUST leave its ticket move in the claim commit. If the
        # commit still came out empty, a concurrent default op ate the snapshot
        # anyway — roll back and have the user retry rather than mint an empty claim.
        and if set -q _flag_claim_todo; and jj log --no-graph -r $name -T 'empty' --ignore-working-copy | string match -q true
            echo >&2 "$(status filename): $name's claim commit is empty — the ticket move was lost (a concurrent op on default). Nothing kept; re-run 'claim $name'."
            false
        end
        or begin
            echo >&2 "Failed... restoring to $savepoint"
            jj op restore "$savepoint"
            # `workspace add` may have created $ws_dir on disk; op restore drops the
            # workspace from jj's view but leaves the directory. We confirmed it didn't
            # exist before, so this partial is ours to remove — else a retry trips on it.
            rm -rf "$ws_dir"
            return 1
        end
    end
    # The jj structure is committed; now hang the shared dirs off the new
    # workspace. A provisioning failure leaves a valid-but-bare workspace — op
    # restore can't undo symlinks/generated files anyway, so don't roll back.
    and __provision_ws "$ws_dir"
end

# `claim TODO` spins up a fresh workspace + claim for TODO (the common path).
# `claim TODO... --into NAME` instead folds each TODO into the EXISTING workspace
# NAME's claim, so one workspace can own several tickets. Without --into it is exactly
# the old single-todo behavior.
function __workflow_claim
    # -S/--strict-longopts: no abbreviation — only the exact `--into` is accepted, so a
    # typo like `--in` errors loudly instead of silently standing in for `--into`.
    argparse -S 'into=' -- $argv
    or return
    if set -q _flag_into
        __workflow_adopt "$_flag_into" $argv
    else
        # One workspace per TODO on this path — extra TODOs would be silently
        # dropped by __workflow_start (it reads only $argv[1]). Refuse instead.
        if set -q argv[2]
            echo >&2 "$(status filename): 'claim' without --into starts ONE workspace for ONE todo — claim them one at a time, or fold extras into an existing workspace with 'claim TODO... --into NAME'."
            return 2
        end
        __workflow_start --claim-todo $argv
    end
end

# Fold one or more TODOs' ticket-moves into NAME's existing claim commit, so the one
# workspace now owns them all ("oh, I guess we're fixing these too now"). Runs from
# default — the claim commit is immutable from the feature workspace, so it can only
# be amended here. Each ticket is moved triage/->wip/ in default@'s working copy (via
# __claim_todo: same rules and census-mint as a normal claim), then the moves are
# SCOPED-squashed into NAME's claim commit, naming exactly the two paths per ticket so
# default@'s unrelated in-flight strays stay put (the hazard integrate's scoped commit
# also guards). `abandon NAME` then reverts every folded move for free, and `integrate
# NAME` finishes them all. Leaves NAME's workspace stale (its claim parent was
# rewritten) — that is routine: the feature agent clears it with one `workspace
# update-stale`, having committed first to keep the update clean.
function __workflow_adopt
    set -l into $argv[1]
    set -l tickets $argv[2..]
    set -l tdir "$project_dir/docs/tickets"

    if not set -q tickets[1]
        echo >&2 "$(status filename): 'claim --into $into' needs at least one TODO to fold in."
        return 2
    end
    # NAME must be a live feature: a workspace to own the tickets, and a claim commit
    # (its bookmark) to amend. An ad-hoc `start`ed NAME has both too.
    set -l ws_dir (jj workspace root --name "$into")
    or return
    if not jj bookmark list -T 'name ++ "\n"' | string match -q -- "$into"
        echo >&2 "$(status filename): no claim bookmark '$into' to fold into (is it a live workspace?)."
        return 1
    end

    set -l savepoint (jj op log -G -n1 -T 'id.short()')
    or return
    begin
        # Move each ticket triage/->wip/ in default@, collecting the exact paths to
        # squash: the new wip/ path always, plus the old triage path when it came from
        # one (a census-minted ticket has only the new path). Capture the old path
        # BEFORE __claim_todo moves the file out from under it.
        set -l paths
        set -l ok 1
        for t in $tickets
            for folder in critical planned maybe
                if test -f "$tdir/$folder/$t.md"
                    set -a paths "$tdir/$folder/$t.md"
                    break
                end
            end
            if not __claim_todo $t
                set ok 0
                break
            end
            set -a paths "$tdir/wip/$t.md"
        end
        # Move ONLY those ticket paths down into the claim commit. The bookmark follows
        # the rewrite; default's line and NAME's workspace WC are rebased (the WC goes
        # stale). Any unrelated strays in default@ are left uncommitted in @.
        test $ok -eq 1
        and jj squash --from @ --into "$into" $paths
    end
    or begin
        echo >&2 "Failed... restoring to $savepoint"
        jj op restore "$savepoint"
        return 1
    end

    echo >&2 "$(status filename): folded "(string join ', ' $tickets)" into $into's claim. Its workspace ($ws_dir) is now stale — run 'jj workspace update-stale' there (commit first) before the next commit."
end

function __workflow_abandon
    set name $argv[1]
    set ws_dir (jj workspace root --name "$name")
    or return
    # Capture both targets by change-id up front: the claim commit (before
    # `bookmark forget` drops NAME) and the feature-stack roots — the commits only
    # NAME@ has (`default@..NAME@`, captured before `workspace forget` dissolves
    # NAME@). That stays correct whether the stack still sits on its claim or a
    # no-arg refresh DETACHED it onto the trunk tip; the old `children($name) &
    # ::$name@` form resolved to a TRUNK commit on a detached stack, and its `::`
    # then swept default's line — sibling claims, default@ and all. Guard against
    # an empty list — an empty root with `::` appended would abandon the repo.
    set claim (jj log --no-graph -r "$name" -T 'change_id.short()')
    set roots (jj log --no-graph -r "roots(default@..$name@)" -T 'change_id.short() ++ "\n"')
    if not set -q roots[1]
        echo >&2 "$(status filename): could not locate $name's feature root."
        return 1
    end

    # Strip ignored files NOW: the surgery below opens with `workspace forget`,
    # after which jj can't tell tracked from ignored. If the surgery then fails
    # and rolls back, the live workspace is only missing regenerable files.
    __clean_ignored "$ws_dir"

    set savepoint (jj op log -G -n1 -T 'id.short()')
    and begin
        # Abandon the claim commit AND its feature stack, but not the default
        # line — abandoning the claim reparents that onto the claim's parent.
        # workspace-forget runs first and drops the workspace's empty trailing WC.
        # For a claim with NO work yet that empty WC *is* the only root, so it's
        # gone afterward and only the claim is left to abandon; keep just the
        # roots that still resolve ($live:: expands to nothing when none do).
        jj workspace forget "$name"
        and jj bookmark forget "$name"
        and begin
            set -l live
            for r in $roots
                jj log --no-graph -r "$r" --ignore-working-copy >/dev/null 2>&1
                and set -a live $r
            end
            jj abandon "$claim" $live::
        end
        or begin
            echo >&2 "Failed... restoring to $savepoint"
            jj op restore "$savepoint"
            return 1
        end
    end
    and __retire_ws "$ws_dir" .abandoned
end

# refresh has two shapes, keyed on where it's run:
#   • from a FEATURE WORKSPACE, no WORKSPACE arg (the common case) — DETACH: rebases that
#     workspace's stack onto the trunk tip (default@-), separating it from its claim.
#     integrate re-joins the claim. The in-place "get review-ready" call an agent makes.
#   • from DEFAULT with a WORKSPACE name — the old REORDER: slides the claim to just under
#     default@, feature stack carried along, so claim+feature stay together at the top of
#     default's line. refresh --all reorders every non-default workspace this way (prep
#     for a push). Both bring the feature current with trunk; they differ only in topology
#     (detached-onto-trunk vs. claim-reordered-under-default@).
# "Stop at the first problem": the first workspace that conflicts (69) or fails (1) ends a
# --all run and propagates its status; the rest are left for a clean re-run. Refreshing an
# already-current feature is a harmless no-op either way.
function __workflow_refresh
    # -S: never abbreviate --all (standing rule — exact long opts only).
    argparse -S a/all -- $argv
    or return

    set -l on_default (test "$(jj workspace root)" = "$(jj workspace root --name default)"; and echo 1)

    if set -q _flag_all
        if set -q argv[1]
            echo >&2 "$(status filename): 'refresh --all' takes no WORKSPACE name (got '$argv[1]')."
            return 2
        end
        # Reorder rewrites default's shared line — it must hold DEFAULT's lock. From
        # a feature workspace this run re-exec'd under that workspace's private lock,
        # which serializes against nothing that touches default.
        if test -z "$on_default"
            echo >&2 "$(status filename): 'refresh --all' rewrites default's shared line — run it from the default workspace."
            return 2
        end
        # Every workspace but the default coordinator, in jj's (alphabetical) order.
        set -l targets
        for ws in (jj workspace list -T 'name ++ "\n"')
            test "$ws" = default; or set -a targets "$ws"
        end
        if not set -q targets[1]
            echo >&2 "$(status filename): no non-default workspaces to refresh."
            return 0
        end
        for ws in $targets
            echo >&2 "$(status filename): refreshing $ws"
            __refresh_reorder "$ws"; or return    # stop at the first conflict/failure
        end
        echo >&2 "$(status filename): refreshed "(count $targets)" workspace(s): "(string join ', ' $targets)"."
        return 0
    end

    set -l name $argv[1]
    if test -z "$name"
        # No name → refresh the workspace we're standing in (detach). Not from default.
        # NB: `test -n`, not `set -q` — `set -l on_default (…)` always DEFINES the var
        # (empty when not on default), and `set -q` is true for a defined-but-empty
        # local, so `set -q on_default` was ALWAYS true → no-arg refresh from a feature
        # workspace wrongly took the on-default branch and errored.
        if test -n "$on_default"
            echo >&2 "$(status filename): refresh needs a WORKSPACE name (or --all), or run it from a feature workspace."
            return 2
        end
        __refresh_detach (path basename (jj workspace root))
    else if test -n "$on_default"
        # From default with a name → the old reorder-under-default@.
        __refresh_reorder "$name"
    else
        # From a feature workspace with an explicit name — ONLY its own: this run's
        # flock is the INVOKING workspace's, so detaching another feature's stack
        # from here would race that workspace's own refresh/integrate unserialized.
        # (Basename == workspace name holds for toolkit-created feature workspaces.)
        if test "$name" != (path basename (jj workspace root))
            echo >&2 "$(status filename): refresh '$name' from the default workspace (reorder), or run a no-arg refresh inside $name's own workspace (detach) — refreshing it from here would hold the wrong lock."
            return 2
        end
        __refresh_detach "$name"
    end
end

# DETACH (from a feature workspace, and from integrate): rebase $name's feature stack
# onto the current trunk tip (default@-), detaching it from its claim commit (which stays
# put in default's line — integrate re-joins it). The stack is everything $name@ has that
# default@ lacks (`default@..$name@`); the claim, an ancestor of default@, is excluded. A
# single atomic rebase — jj leaves state untouched on error, so no op-log rollback is
# needed. Idempotent: a feature already on default@- is a jj no-op. Returns 69 (conflict
# left in place) or 1 (failed).
function __refresh_detach
    set name $argv[1]
    set ws_dir (jj workspace root --name "$name"); or return 1
    # An empty stack (`default@..$name@` resolves to nothing — the feature is already
    # fully in default@'s ancestry) means there's nothing to refresh. `jj rebase` would
    # error on an empty -r set, so short-circuit; still clear any staleness.
    # A FAILED `jj log` must be a hard error, not "nothing to refresh": `set` keeps
    # the substitution's status, and an unquoted `test -z (…)` would have read the
    # failure's empty output as an already-integrated stack and returned success.
    set -l stack (jj log --no-graph -r "default@..$name@" -T 'change_id.short()' --ignore-working-copy)
    or return 1
    if test -z "$stack"
        command jj -R "$ws_dir" workspace update-stale >/dev/null 2>&1
        return 0
    end

    jj rebase -r "default@..$name@" -d 'default@-'
    or return 1
    # A rebase conflict is NOT a failure — jj records it and exits 0. The update-stale
    # below materializes it in the workspace; leave it there and return the 69
    # "expected-stop" sentinel (the wrapper maps it to exit 2) so integrate won't fold a
    # conflict into default@. Do NOT treat it as a hard failure.
    set -l conflicted (jj log --no-graph -r "default@..$name@ & conflicts()" -T 'change_id.short() ++ "\n"' --ignore-working-copy)
    # The rebase rewrote $name's WC; clear the resulting staleness. Harmless no-op when
    # refresh ran from $name's own workspace (its WC updated in place). A failure here
    # with no conflict is a real problem (e.g. divergence) — surface it.
    command jj -R "$ws_dir" workspace update-stale
    or test -n "$conflicted"; or return 1
    if test -n "$conflicted"
        echo >&2 "$(status filename): $name now conflicts with the trunk tip — resolve it in $ws_dir, then re-run."
        return 69
    end
end

# REORDER (from default, `refresh NAME` / `--all`): slide $name's claim commit to sit just
# under default@, carrying its feature stack and workspace WC — the old refresh. The claim
# lives in default@'s history, so this is a REORDER, not a rebase-onto. It rewrites
# default's shared line, so it runs under the workflow lock (refresh from default takes
# default's lock). Returns 69 (conflict left in place) or 1 (rolled back).
function __refresh_reorder
    set name $argv[1]
    set ws_dir (jj workspace root --name "$name"); or return 1
    # Feature-stack root: the first commit only NAME@ has — the claim's child when
    # the stack sits on its claim, the detached stack's root after a no-arg refresh
    # (the reorder below then re-attaches it). The old `children($name) & ::$name@`
    # form resolved to a TRUNK commit on a detached stack, and `rebase -s` would
    # have dragged default's line onto the claim. Capture it before the move — its
    # change id survives the rebase even though the commit id won't.
    set root (jj log --no-graph -r "roots(default@..$name@)" -T 'change_id.short() ++ "\n"'); or return 1
    if not set -q root[1]
        echo >&2 "$(status filename): could not locate $name's feature root."
        return 1
    end
    if set -q root[2]
        echo >&2 "$(status filename): $name's stack has multiple roots — reorder can't carry it in one piece; integrate it, or simplify the stack by hand."
        return 1
    end

    set savepoint (jj op log -G -n1 -T 'id.short()')
    and begin
        # -r pulls the claim out of the chain (healing the gap) and --insert-before
        # threads it back in just under default@.
        jj rebase -r "$name" --insert-before default@
        # -r reparented the claim's children — including the feature stack — onto its old
        # parent; pull the feature stack back onto the moved claim commit.
        and jj rebase -s "$root" -d "$name"
        and command jj -R "$ws_dir" workspace update-stale
        or begin
            echo >&2 "Failed... restoring to $savepoint"
            jj op restore "$savepoint"
            return 1
        end
    end

    # A rebase conflict is NOT a failure — jj records it and the rebase exits 0. It's now
    # materialized in the workspace; leave it there and return the 69 "expected-stop"
    # sentinel so integrate won't fold a conflict. Do NOT roll back.
    set -l conflicted (jj log --no-graph -r "$root:: & conflicts()" -T 'change_id.short() ++ "\n"')
    if test -n "$conflicted"
        echo >&2 "$(status filename): $name now conflicts with default@ — resolve it in $ws_dir, then re-run."
        return 69
    end
end

function __integrate_steps
    set name $argv[1]
    set -l ws_dir (jj workspace root --name "$name"); or return
    # Snapshot NAME's on-disk working copy first: every read below runs from
    # default with --ignore-working-copy, so edits made in the workspace after the
    # agent's last jj command would otherwise be invisible — the fold would skip
    # them and the final orphan-abandon would drop them from history. update-stale
    # first so a stale workspace (e.g. after `claim --into`) doesn't fail the
    # snapshot.
    command jj -R "$ws_dir" workspace update-stale >/dev/null 2>&1
    command jj -R "$ws_dir" status >/dev/null
    or return 1
    # Refresh first: detach the feature stack onto the current trunk tip. Always the
    # DETACH path (never the from-default reorder), so the fork_point re-join below has a
    # detached feature to thread the claim back into. This re-establishes currency even
    # if trunk advanced since the agent's last refresh (so the fold never rewinds default@
    # past newer work). Propagate its status verbatim: 69 = it left a conflict in the
    # workspace, so we must NOT fold — bail with the same sentinel, no rollback.
    __refresh_detach "$name"
    or return

    # Re-join the claim to the now-current feature: thread the claim commit back in at
    # the feature's fork point (`fork_point(...)-` is the commit the stack branches
    # from — default@- once the refresh has detached the feature), rebuilding the "claim
    # under default@, feature branching off it" shape the fold below relies on.
    #
    # Only when the feature is actually DETACHED, though: if the refresh above was a
    # no-op (trunk hadn't advanced since the claim), the feature still sits ON its claim
    # and the fork point's parent already IS the claim — `rebase -r NAME -A NAME` would
    # be a cycle. Skip the re-join in that case; the fold shape is already right. So the
    # guard, not a bare rebase, is what makes refresh+rejoin idempotent across re-runs.
    set -l fork_parent (jj log --no-graph -r "fork_point(default@..$name@)-" -T 'change_id.short()' --ignore-working-copy)
    set -l claim_cid (jj log --no-graph -r "$name" -T 'change_id.short()' --ignore-working-copy)
    if test -n "$fork_parent" -a "$fork_parent" != "$claim_cid"
        jj rebase -r "$name" -A "fork_point(default@..$name@)-"
        or return 1
        # The re-join reparented the feature stack onto the claim → the workspace WC is
        # now stale; clear it before the inspection / cap below touch the workspace.
        command jj -R "$ws_dir" workspace update-stale >/dev/null 2>&1
        # As with refresh, a re-join conflict (the claim's ticket-move vs. trunk) is
        # recorded and exits 0. Leave it for the workspace to resolve; bail 69, no fold.
        set -l rejoin_conflict (jj log --no-graph -r "$name:: & conflicts()" -T 'change_id.short()' --ignore-working-copy)
        if test -n "$rejoin_conflict"
            echo >&2 "$(status filename): re-joining $name's claim conflicts with the trunk tip — resolve it in $ws_dir, then re-run."
            return 69
        end
    end

    # Inspect the workspace's working-copy commit. A clean hand-off has emptiness
    # and describedness AGREEing: either an empty undescribed @ (the agent ended on
    # `jj new`), or the finished work sitting in @ described-but-not-`new` (a common
    # habit). When they DISAGREE it's work in flight — stop (69), don't fold:
    #   - empty + described  -> a set-up-but-unfilled commit; looks in-progress.
    #   - nonempty + undescribed -> uncommitted/undescribed work.
    set -l wc_empty (jj log --no-graph -r "$name"@ -T 'if(empty, "y", "")' --ignore-working-copy)
    set -l wc_desc (jj log --no-graph -r "$name"@ -T 'if(description, "y", "")' --ignore-working-copy)
    if test -n "$wc_empty" -a -n "$wc_desc"
        echo >&2 "$(status filename): $name@ is described but empty — that reads as work in progress. Finish it, or clear the description / abandon it, then re-integrate."
        return 69
    else if test -z "$wc_empty" -a -z "$wc_desc"
        echo >&2 "$(status filename): $name has undescribed work in its workspace — describe it (jj describe -m …) or abandon it, then re-integrate."
        return 69
    else if test -z "$wc_empty" -a -n "$wc_desc"
        # Finished work left AS the working copy (describe-but-not-`new`). Cap it
        # with a fresh empty commit IN the feature workspace, so the work becomes
        # $name@- and the fold below (default@ onto $name@-, drop the empty tip)
        # picks it up — exactly as if the agent had run `jj new` themselves.
        command jj -R "$ws_dir" new
        or begin
            echo >&2 "$(status filename): couldn't cap $name's described work with an empty commit."
            return 1
        end
    end
    # else: empty + undescribed — already the clean trailing-commit shape.

    # Fold: move default's @ onto the feature tip, finish the todo as the final
    # commit. `jj workspace forget` is the point of no return — op restore can't
    # un-forget — so it runs LAST, after every fail-able step. A failure before it
    # rolls back cleanly; forget itself then drops the now-empty WC for us.
    set -l orphan (jj log --no-graph -r "$name"@ -T 'change_id.short()')
    # The tickets THIS claim owns are exactly the wip/ tickets its claim commit adds:
    # one for a plain claim, several once `claim --into` has folded more in, none for
    # an ad-hoc `start`. Read them off the claim commit's own diff so a multi-ticket
    # claim finishes them ALL. jj prints diff paths relative to CWD, so anchor at the
    # workspace root to keep the match stable wherever integrate was invoked from.
    set -l prev_pwd "$PWD"
    cd "$project_dir"
    set -l slugs
    for p in (jj diff -r "$name" --name-only --ignore-working-copy)
        set -l s (string match -rg '^docs/tickets/wip/(.+)\.md$' -- $p)
        test -n "$s"; and set -a slugs $s
    end
    cd "$prev_pwd"
    # The wip+done path pair for every owned ticket. Naming them explicitly scopes the
    # completion commit to ONLY the ticket moves: the rebase folded default@'s working
    # copy — the shared coordinator copy, routinely carrying unrelated in-flight edits
    # — onto the feature tip, and a bare `jj commit` would sweep those strays into
    # "complete …" (exactly how a concurrent integrate once swallowed an unrelated
    # edit). Ad-hoc features own no tickets, so there's nothing to commit.
    set -l move_paths
    for s in $slugs
        set -a move_paths "$project_dir/docs/tickets/wip/$s.md" "$project_dir/docs/tickets/done/$s.md"
    end

    jj rebase -r @ -d "$name"@-
    # A fold conflict (default@'s in-flight strays vs. the feature) is recorded
    # with exit 0, like every jj rebase conflict. Its siblings (__refresh_detach,
    # the re-join) leave theirs in the feature workspace as 69 — but this one sits
    # on default@ ITSELF, and proceeding would retire the workspace around a
    # permanently conflicted trunk tip. Fail (1) so the caller rolls it all back.
    and begin
        set -l fold_conflict (jj log --no-graph -r '@ & conflicts()' -T 'change_id.short()' --ignore-working-copy)
        test -z "$fold_conflict"
        or begin
            echo >&2 "$(status filename): folding default@ onto $name's tip conflicts — rolling back; commit or clear default@'s in-flight edits, then re-integrate."
            false
        end
    end
    and __check_todo $slugs
    and if set -q slugs[1]
        jj commit -m "complete $(string join ' ' $slugs)" $move_paths
    end
    # Strip ignored files while jj still knows the workspace (`workspace forget`
    # below cuts that off) — the archive mv shouldn't drag build junk along.
    and __clean_ignored "$ws_dir"
    # Drop the now-folded claim bookmark (its commit lives on in default@'s history;
    # the ref is just clutter). Before workspace forget so a failure still rolls back.
    and jj bookmark forget "$name"
    and jj workspace forget "$name"
    # forget already drops the empty WC; clean up only if it somehow survived, and
    # never let that become a post-forget failure (op restore can't un-forget).
    and if jj log --no-graph -r "$orphan" >/dev/null 2>&1
        jj abandon "$orphan"
    end
end

function __workflow_integrate
    set name $argv[1]
    set ws_dir (jj workspace root --name "$name")
    or return

    set savepoint (jj op log -G -n1 -T 'id.short()')
    or return

    __integrate_steps "$name"
    switch $status
        case 0
            __retire_ws "$ws_dir" .integrated
        case 69
            # Expected stop (conflict or uncommitted work) — state left in place for
            # the user to resolve. Do NOT roll back.
            return
        case '*'
            echo >&2 "Failed... restoring to $savepoint"
            jj op restore "$savepoint"
            return 1
    end
end

# Heal a working-copy divergence (two+ commits sharing @'s change id, left when a
# concurrent op rewrote @ while this workspace had un-snapshotted edits). Keep the
# half holding your work (the non-empty one), drop the empty redundant half(s) — in
# ONE pass, so a concurrent op can't interrupt a multi-step hand-fix. REFUSES when
# two halves hold genuinely different non-empty work (a real conflict — resolve by
# hand). Run this FROM the affected feature workspace.
function __workflow_converge
    jj workspace update-stale 2>/dev/null    # clear staleness first; safe under the guards
    set -l cid (jj log --no-graph --ignore-working-copy -r @ -T 'change_id')
    set -l commits (jj log --no-graph --ignore-working-copy -r "change_id($cid)" \
        -T 'commit_id.short() ++ "\n"')
    if test (count $commits) -le 1
        echo "converge: @ is not divergent — nothing to do."
        return 0
    end
    # The work lives in the non-empty half; identify by content, never by /N index.
    set -l nonempty
    for c in $commits
        jj log --no-graph --ignore-working-copy -r $c -T 'empty' | string match -q true
        or set -a nonempty $c
    end
    set -l keep
    switch (count $nonempty)
        case 0
            set keep $commits[1]   # all empty → identical; keep any
        case 1
            set keep $nonempty[1]  # one real half + empty placeholder(s)
        case '*'
            set keep $nonempty[1]  # multiple non-empty: only safe if byte-identical
            for c in $nonempty[2..]
                if test -n "$(jj diff --ignore-working-copy --from $keep --to $c)"
                    echo >&2 "converge: divergent halves hold DIFFERENT work ($keep vs $c) — resolve by hand (jj edit the right one, jj abandon the others)."
                    return 1
                end
            end
    end
    set -l drop
    for c in $commits
        test "$c" = "$keep"; or set -a drop $c
    end
    # Make the keeper @, then drop the rest. Editing the keeper may auto-hide the
    # empty half, so a "nothing to abandon" here is success, not failure.
    jj edit $keep
    or return 1
    jj abandon $drop 2>/dev/null
    echo "converge: kept $keep, dropped: $drop"
end

# Walk a feature stack's conflicts after a refresh/integrate left them, resolving
# them oldest-first IN PLACE (no flattening). The loop you run from the feature
# workspace:
#   - `scripts/workflow resolve` drops you onto a conflicted commit and exits 1,
#   - remove every conflict marker from the files `jj st` lists,
#   - re-run `resolve`: it folds your fix into that commit and moves to the next.
# Repeat until exit 0 (stack clean — re-integrate). Exit 2 = you left markers
# behind, or a jj step broke and was rolled back. The `$name-tip` bookmark is the
# cursor marking the real tip while you descend onto each conflict. For a
# working-copy DIVERGENCE (not a refresh conflict), use `converge` instead.
function __workflow_resolve
    # Dir basename == workspace name holds only for FEATURE workspaces (claim/start
    # create ../NAME). The default workspace's dir name is free — but resolve's
    # contract is to run from a feature workspace, so basename is safe here.
    set -l name (path basename (jj workspace root))
    set -l tipbm "$name-tip"
    set -l savepoint (jj op log -n1 -G -T 'id.short()')

    # Mid-descent: the cursor exists, so @ is your edit of one conflicted commit.
    if jj bookmark list -T 'name ++ "\n"' | string match -q -- "$tipbm"
        if jj resolve --list >/dev/null 2>&1   # exit 0 => @ still has conflicts
            echo >&2 "resolve: @ still has conflict markers — remove them all (jj st lists the files), then re-run."
            return 2
        end
        # Fold @'s resolution into the commit it sits on, then hop to the real tip
        # so the scan below spans the whole stack.
        begin
            if test -n "$(jj log -G -r '@- & conflicts()')"
                jj squash
            end
        end
        and jj edit "$tipbm"
        and jj bookmark forget "$tipbm"
        or begin
            echo >&2 "resolve: a jj step failed — rolled back. Resolve by hand or ask for help."
            jj op restore "$savepoint"
            return 2
        end
    end

    # Remaining conflicts in this feature's stack (oldest last; jj lists newest-first).
    set -l conflicts (jj log -G -r "$name+::@ & conflicts()" -T 'change_id.short() ++ "\n"')
    if set -q conflicts[1]
        begin
            jj bookmark create "$tipbm"
            and jj new $conflicts[-1]
        end
        or begin
            echo >&2 "resolve: a jj step failed — rolled back. Resolve by hand or ask for help."
            jj op restore "$savepoint"
            return 2
        end
        echo >&2 "resolve: editing the oldest of "(count $conflicts)" conflicted commit(s). Remove all markers (jj st), then re-run resolve."
        return 1
    else
        echo >&2 "resolve: all conflicts resolved on $name@ — re-run 'scripts/workflow integrate $name'."
        return 0
    end
end

# One-stop recovery for "my branch shifted under me." Run FROM the feature
# workspace. Order: clear staleness, heal a working-copy divergence (only if there
# is one), then walk any refresh/integrate conflicts (only if there are any).
# Labels its own outcome — exit 0 = clean (re-integrate); exit 1 = you're on a
# conflicted commit, remove its markers (jj st) and re-run `repair`; exit 2 = a
# human is needed (divergent halves hold different work, or a jj step rolled back).
function __workflow_repair
    # Basename == workspace name: safe only because repair runs from a feature
    # workspace (toolkit-created as ../NAME); default's dir name is unconstrained.
    set -l name (path basename (jj workspace root))
    # Clear a stale working copy — that's what surfaces a divergence or conflicts.
    jj workspace update-stale 2>/dev/null
    # Heal a working-copy divergence, only if there actually is one.
    set -l div (jj log -G -r "$name::$name@ & divergent()")
    if test -n "$div"
        __workflow_converge
        or begin
            echo >&2 "repair: the two divergent halves hold genuinely different work — a human is needed."
            return 2
        end
    end
    # Walk refresh/integrate conflicts, only if there are any (incl. mid-walk).
    set -l conf (jj log -G -r "$name::$name@ & conflicts()")
    if test -z "$conf"
        echo >&2 "repair: branch clean — carry on (re-integrate if you were mid-integrate)."
        return 0
    end
    # Let resolve do the walking, but keep its (and jj's) chatter quiet — repair
    # owns the conflict output below, including the file list.
    __workflow_resolve >/dev/null 2>&1
    set -l rc $status
    switch $rc
        case 0
            echo >&2 "repair: conflicts resolved — branch clean, re-integrate."
        case 1
            echo >&2 "repair: stopped on a conflict. For each file above, resolve with:"
            echo >&2 "    scripts/conflicts accept FILE stack          (both sides added — stack them)"
            echo >&2 "    scripts/conflicts accept FILE snapshot|diff  (pick one side)"
            echo >&2 "    [edit FILE directly]                         (complex/semantic conflict)"
            echo >&2 "Then re-run 'scripts/workflow repair'."
            echo >&2 ""
            for f in (jj resolve --list 2>/dev/null | string replace -r '\s.*$' '')
                echo >&2 "    $f"
            end
            echo >&2 ""
            $scripts_dir/conflicts show >&2
        case '*'
            echo >&2 "repair: stopped (exit $rc) — finish removing markers and re-run, or get a human if jj rolled back."
    end
    return $rc
end

# Serialize the transactional commands so two sessions sharing default@ can't
# interleave and corrupt the shared op log — or race a ticket move out of a claim
# commit, the window __workflow_start flags by hand. claim/start/abandon/integrate and
# `refresh NAME`/`--all` (from default) mutate the shared default line. The lock keys on
# a per-repo lockfile in the INVOKING workspace's .jj/, which lands exactly right: a
# from-default refresh takes default's lock (serializing its reorder against those), while
# a from-workspace `refresh` (which only rewrites its own isolated feature stack — a single
# atomic rebase that reads default@- but never writes default's line) takes that
# workspace's own private, uncontended lock — effectively instant, so an agent never waits
# to refresh. repair/converge/resolve heal an isolated feature workspace and are
# deliberately lock-free. Re-exec the whole command under an flock on that lockfile (jj
# never snapshots .jj/, so it can't leak into a commit): the lock covers the ENTIRE
# operation — every jj step plus its rollback — and is released when this process exits,
# even on a crash (the kernel drops the lock when flock's fd closes). _WORKFLOW_LOCKED
# breaks the re-exec recursion. This internalizes the external `flock <lock>
# scripts/workflow …` wrapper the parallel-worker recipe used to apply by hand.
if not set -q _WORKFLOW_LOCKED; and contains -- "$argv[1]" claim start abandon refresh integrate
    set -gx _WORKFLOW_LOCKED 1
    # -w 600: wait up to 10 min (a held lock spans one op, incl. claim/start's slow
    # workspace provisioning) rather than failing fast under contention. -E 75: on
    # timeout exit 75, distinct from the command's own codes (incl. 2), so a genuine
    # "couldn't acquire" is never mistaken for the operation's result.
    flock -w 600 -E 75 "$project_dir/.jj/workflow.lock" "$scripts_dir/workflow" $argv
    set -l rc $status
    if test $rc -eq 75
        echo >&2 "$(status filename): timed out waiting for the workflow lock — another claim/start/abandon/refresh/integrate is holding it. Re-run once it finishes."
        return 1
    end
    return $rc
end

switch $argv[1]
    case claim
        __workflow_claim $argv[2..]
    case start
        __workflow_start $argv[2..]
    case abandon
        __workflow_abandon $argv[2..]
    case integrate
        __workflow_integrate $argv[2..]
    case refresh
        __workflow_refresh $argv[2..]
    case repair
        __workflow_repair
    case converge
        __workflow_converge
    case resolve
        __workflow_resolve
    case '*'
        __workflow_usage
end
switch $status
    case 69
        return 2
    case '*'
        return
end
